# Telegram API credentials (get from https://my.telegram.org)
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+1234567890

# OpenAI API key (for Whisper transcription)
OPENAI_API_KEY=your_openai_api_key

# Mode: test or production (default: production)
# In test mode, the agent will use mock responses instead of real API calls
MODE=production

# Format transcriptions with LLM for better readability (default: true)
# When enabled, uses Llama 3.1 8B Instant via Groq to add paragraph breaks
FORMAT_TRANSCRIPTIONS=true

# Chats to skip (comma-separated list of chat IDs, @usernames, or chat titles)
# Voice messages in these chats will NOT be transcribed.
# Examples: SKIP_CHATS=699561995,-1001234567890,@channel_name,My Group Chat
SKIP_CHATS=
